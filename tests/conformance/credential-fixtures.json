{
  "tests": [
    {
      "name": "cred_init",
      "request": {
        "jsonrpc": "2.0",
        "id": 1,
        "method": "initialize",
        "params": {
          "protocolVersion": "2024-11-05",
          "capabilities": {},
          "clientInfo": { "name": "credential-test", "version": "1.0" }
        }
      },
      "expect": {
        "jsonrpc": "2.0",
        "id": 1,
        "result": { "protocolVersion": "2024-11-05" }
      },
      "match": "partial"
    },
    {
      "name": "cred_initialized",
      "request": {
        "jsonrpc": "2.0",
        "method": "notifications/initialized"
      },
      "match": "silent"
    },
    {
      "name": "cred_env_injected",
      "request": {
        "jsonrpc": "2.0",
        "id": 10,
        "method": "tools/call",
        "params": {
          "name": "crm_check_creds",
          "arguments": {}
        }
      },
      "expect_content_json": { "has_credentials": true, "value": "test-secret-123" },
      "match": "content_json"
    },
    {
      "name": "cred_no_namespace",
      "request": {
        "jsonrpc": "2.0",
        "id": 11,
        "method": "tools/call",
        "params": {
          "name": "nocreds_check_creds",
          "arguments": {}
        }
      },
      "expect_content_json": { "has_credentials": false },
      "match": "content_json"
    }
  ]
}
