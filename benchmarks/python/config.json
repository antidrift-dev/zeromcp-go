{
  "language": "python",
  "servers": [
    {
      "label": "official",
      "command": "python3",
      "args": ["/bench/official.py"]
    },
    {
      "label": "zeromcp",
      "command": "python3",
      "args": ["-m", "zeromcp", "serve", "/zeromcp/python/examples/tools"],
      "env": { "PYTHONPATH": "/zeromcp/python" }
    }
  ]
}
