{
  "language": "ruby",
  "servers": [
    {
      "label": "official",
      "command": "ruby",
      "args": ["/bench/official/server.rb"],
      "env": { "BUNDLE_GEMFILE": "/bench/official/Gemfile" }
    },
    {
      "label": "zeromcp",
      "command": "ruby",
      "args": ["-I", "/zeromcp/ruby/lib", "/zeromcp/ruby/bin/zeromcp", "serve", "/zeromcp/ruby/tools"]
    }
  ]
}
